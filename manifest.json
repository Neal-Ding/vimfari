{
  "manifest_version": 3,
  "name": "Vimfari",
  "version": "1.0.0",
  "description": "The Hacker's Browser for Safari. Vimfari provides keyboard shortcuts for navigation and control in the spirit of Vim. Ported from Vimium.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background_scripts/background.bundle.js"
  },
  "options_ui": {
    "page": "pages/options.html",
    "browser_style": false,
    "open_in_tab": true
  },
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "permissions": [
    "tabs",
    "bookmarks",
    "history",
    "storage",
    "sessions",
    "notifications",
    "scripting",
    "webNavigation"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "lib/safari_polyfill.js",
        "lib/types.js",
        "lib/utils.js",
        "lib/keyboard_utils.js",
        "lib/dom_utils.js",
        "lib/rect.js",
        "lib/handler_stack.js",
        "lib/settings.js",
        "lib/find_mode_history.js",
        "content_scripts/mode.js",
        "content_scripts/ui_component.js",
        "content_scripts/link_hints.js",
        "content_scripts/vomnibar.js",
        "content_scripts/scroller.js",
        "content_scripts/marks.js",
        "content_scripts/mode_insert.js",
        "content_scripts/mode_find.js",
        "content_scripts/mode_key_handler.js",
        "content_scripts/mode_visual.js",
        "content_scripts/hud.js",
        "content_scripts/mode_normal.js",
        "content_scripts/vimium_frontend.js"
      ],
      "css": [
        "content_scripts/vimium.css"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/action_disabled_16.png",
      "32": "icons/action_disabled_32.png"
    },
    "default_popup": "pages/action.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "pages/vomnibar_page.html",
        "content_scripts/vimium.css",
        "pages/hud_page.html",
        "pages/help_dialog_page.html",
        "pages/doc_search_completion.html",
        "pages/command_listing.html",
        "resources/tlds.txt"
      ],
      "matches": [
        "http://*/*",
        "https://*/*"
      ]
    }
  ]
}
